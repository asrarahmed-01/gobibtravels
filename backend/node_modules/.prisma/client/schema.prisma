// Prisma schema — single source of truth for the database structure.
// Run `npm run prisma:migrate` after editing this file to generate a migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Phase 1: Authentication ---

enum Role {
  CUSTOMER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  refreshToken String? // hashed refresh token for the currently active session
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}
